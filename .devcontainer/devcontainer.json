{
    "name": "firecracker-agentfs",
    "build": {
        "context": ".",
        "dockerfile": ".devcontainer/Dockerfile"
    },
    "remoteUser": "vscode",
    "workspaceFolder": "/home/vscode/workspaces/firecracker-agentfs",
    "workspaceMount": "source=${localWorkspaceFolder},target=/home/vscode/workspaces/firecracker-agentfs,type=bind",
    "runArgs": [
        "--device=/dev/kvm:/dev/kvm",
        "--cap-add=SYS_ADMIN",
        "--privileged",
        "--memory=4g",
        "--cpus=2"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.shell-syntax",
                "ms-vscode.makefile-tools",
                "redhat.vscode-yaml",
                "ms-python.python",
                "esbenp.prettier-vscode",
                "davidanson.vscode-markdownlint"
            ],
            "settings": {
                "terminal.integrated.defaultProfile.linux": "bash",
                "files.eol": "\n",
                "files.trimTrailingWhitespace": true,
                "editor.formatOnSave": true,
                "bash-debug.configuration.bashPath": "/usr/bin/bash",
                "[shellscript]": {
                    "editor.defaultFormatter": "esbenp.prettier-vscode"
                }
            }
        }
    },
    "forwardPorts": [],
    "postCreateCommand": "echo 'Dev container ready! Firecracker: $FIRECRACKER_PATH, AgentFS: $AGENTFS_PATH, opencode: $OPCODE_PATH'",
    "containerEnv": {
        "FIRECRACKER_PATH": "/usr/local/bin/firecracker",
        "AGENTFS_PATH": "/usr/local/bin/agentfs",
        "OPCODE_PATH": "/usr/local/bin/opencode",
        "FIRECRACKER_VERSION": "v1.15.1",
        "AGENTFS_VERSION": "0.6.4",
        "AGENTFS_DB_PATH": "/home/vscode/.agentfs"
    }
}
